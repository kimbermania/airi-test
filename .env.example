# ================================================
# AIRI Self-Hosting Environment Variables
# ================================================
# Portainer 사용 시: Stack → Environment variables에
# 아래 변수들을 직접 입력하세요. 이 파일은 필요한 변수 목록을 문서화합니다.
#
# 로컬에서 docker compose를 직접 실행하는 경우:
# cp .env.example .env 후 실제 값을 채워서 사용하세요.
# .env 파일은 .gitignore에 의해 Git에 커밋되지 않습니다.
# ================================================

# --- LLM 설정 ---
LLM_PROVIDER=google
LLM_API_KEY=
LLM_MODEL=gemini-2.0-flash

# --- 포트 설정 (기본값 있음, 충돌 시에만 변경) ---
AIRI_WEB_PORT=3000
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_ADMIN_PORT=81
